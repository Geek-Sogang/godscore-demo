# ══════════════════════════════════════════════════════════════
# 하나 더 (Hana More) — .gitignore
# React Native (Expo) + TypeScript + FastAPI + Python
# ══════════════════════════════════════════════════════════════

# ─── 환경변수 / 시크릿 (절대 커밋 금지) ─────────────────────
.env
.env.local
.env.*.local
.env.production
backend/.env
backend/.env.*

# ─── Node.js / React Native / Expo ────────────────────────
node_modules/
.expo/
dist/
web-build/
npm-debug.*
yarn-debug.*
yarn-error.*
.pnp
.pnp.js

# ─── 네이티브 빌드 아티팩트 ────────────────────────────────
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
ios/
android/

# ─── Python / FastAPI ──────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# 가상환경 (pip/venv/poetry 모두 대응)
.venv/
venv/
env/
.env/
ENV/
env.bak/
venv.bak/
backend/.venv/

# 빌드/패키징
build/
dist/
develop-eggs/
eggs/
.eggs/
*.egg-info/
*.egg
MANIFEST
sdist/
wheels/

# ─── ML 모델 파일 (용량 크므로 제외, init_model.py 로 재생성) ─
backend/models/*.pkl
backend/models/*.joblib
backend/models/*.bin
backend/*.pkl
*.pkl
*.joblib

# ─── 테스트 / 커버리지 ─────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
nosetests.xml
*.cover

# ─── 로그 ─────────────────────────────────────────────────
*.log
pip-log.txt
pip-delete-this-directory.txt

# ─── OS / 에디터 ───────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
.cursorignore
.cursorindexingignore

# ─── 타입 체커 / 린터 캐시 ─────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.eslintcache

# ─── Jupyter ───────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─── 캐시 ─────────────────────────────────────────────────
.cache/
.parcel-cache/
