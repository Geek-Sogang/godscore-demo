# 하나 더 (Hana More) - 백엔드 환경변수 예시
# cp .env.example .env 후 실제 값으로 교체
# ⚠️ .env 파일은 절대 Git에 커밋하지 말 것!

APP_NAME="하나 더 (Hana More) API"
APP_VERSION="1.0.0"
DEBUG=true

# Supabase 대시보드 > Settings > API 에서 확인
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key-here

# Supabase 대시보드 > Settings > API > JWT Secret
JWT_SECRET=your-supabase-jwt-secret-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Expo Web: 8081, Expo Go: 19006
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://127.0.0.1:8081

REDIS_URL=redis://localhost:6379/0

# 데모 환경: 모두 true (실제 API 키 불필요)
BLOCKCHAIN_MOCK_MODE=true
GPT_API_MOCK_MODE=true
OPENAI_API_KEY=mock-key-not-required-in-demo

MODEL_PATH=app/services/models/godscore_xgb.pkl
